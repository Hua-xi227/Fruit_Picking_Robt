<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.fruitpickingrobt.dao.LoginDAO">

    <resultMap id="UserMap" type="org.example.fruitpickingrobt.entity.User">
        <id column="id" property="id"/>
        <result column="email" property="email"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="phone" property="phone"/>
        <result column="role" property="role"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="updated_time" property="updateTime"/>
    </resultMap>

    <insert id="insertUser" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (email, password, nickname, phone, role, status, create_time, updated_time)
        VALUES (#{email}, #{password}, #{nickname}, #{phone}, #{role}, #{status}, NOW(), NOW())
    </insert>

    <select id="selectUserByUsername" resultMap="UserMap">
        SELECT * FROM users WHERE nickname = #{nickname}
    </select>

    <select id="selectUserByEmail" resultMap="UserMap">
        SELECT * FROM users WHERE email = #{email}
    </select>

    <select id="selectUserById" resultMap="UserMap">
        SELECT * FROM users WHERE id = #{id}
    </select>
    <!-- 根据手机号查询 -->
    <select id="selectUserByPhone" resultMap="UserMap">
        SELECT * FROM users WHERE phone = #{phone}
    </select>
    <!-- 动态更新：只更新非空字段 -->
    <update id="updateUserSelective" parameterType="org.example.fruitpickingrobt.entity.User">
        UPDATE users
        <set>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            updated_time = NOW()
        </set>
        WHERE id = #{id}
    </update>
    <!-- 逻辑删除用户 -->
    <update id="logout">
        UPDATE users
        SET status = 0, updated_time = NOW()
        WHERE id = #{userId}
    </update>

    <update id="updateUserById">
        UPDATE users
        <set>
            <if test="password != null">password = #{password},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="status != null">status = #{status},</if>
            updated_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateUserByUsername">
        UPDATE users
        SET password = #{password}, updated_time = NOW()
        WHERE nickname = #{nickname}
    </update>

    <!--更新用户角色-->
    <update id="updateUserRole">
        UPDATE users
        SET role = #{role}, updated_time = NOW()
        WHERE id = #{userId}
    </update>

    <select id="checkUsernameExists" resultType="int">
        SELECT COUNT(*) FROM users WHERE nickname = #{nickname}
    </select>

    <select id="checkEmailExists" resultType="int">
        SELECT COUNT(*) FROM users WHERE email = #{email}
    </select>

    <select id="countAllUsers" resultType="int">
        SELECT COUNT(*) FROM users
    </select>

    <select id="checkPhoneExists" resultType="int">
        SELECT COUNT(*) FROM users WHERE phone = #{phone}
    </select>

</mapper>